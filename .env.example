# Jira Configuration
JIRA_SERVER=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_TOKEN=your-atlassian-api-token
JIRA_ESCALATION_PROJECT=SHOP

# GitHub Configuration
GH_TOKEN=ghp_your_github_token
GH_REPO=org/repo-name

# Slack Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL_IDS=C01234567,C02345678

# AI Engine (Groq) Configuration
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Agentic Execution & Alerts
AGENT_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
AGENT_STAKEHOLDER_WEBHOOK_URL=https://hooks.slack.com/services/...
AGENT_MEMORY_FILE=agent_memory_history.json
AGENT_MEMORY_MAX_RUNS=60

# Security (Optional)
DELIVERY_HEALTH_API_KEY=your-custom-api-key
